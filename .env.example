# ============================================================
# Consultancy Intelligence Agent – Environment Configuration
# ============================================================
# Copy this file to .env and adjust values as needed.

# --- AI Model Settings ---
# Embedding model from sentence-transformers (downloaded automatically)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# HuggingFace text-generation model (used when USE_LLM=true)
LLM_MODEL=google/flan-t5-small

# Set to "true" to use a real LLM for generation; "false" uses template-based fallback
USE_LLM=false

# --- Server Settings ---
HOST=0.0.0.0
PORT=8000

# --- Slack Integration ---
# Slack incoming webhook URL (leave empty or set to "mock" for local development)
SLACK_WEBHOOK_URL=mock

# --- Data Paths ---
KNOWLEDGE_BASE_DIR=data/knowledge_docs
GRANTS_CSV_PATH=data/grants.csv

# --- Logging ---
LOG_LEVEL=INFO

# --- LLM API Keys ---
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# --- LLM Configuration ---
LLM_PROVIDER=gemini
FAILPROOF_LLM=true
USE_LLM=true
